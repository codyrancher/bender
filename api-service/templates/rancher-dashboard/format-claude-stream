#!/usr/bin/env python3
"""Format `claude -p --output-format stream-json --verbose` NDJSON (stdin) as
live human-readable text on stdout. Run with `python3 -u` for unbuffered output.
"""
import sys
import json


def brief(obj, limit=500):
    s = obj if isinstance(obj, str) else json.dumps(obj, separators=(',', ':'))
    if len(s) <= limit:
        return s
    return s[:limit] + '…'


def print_flushed(*args, **kwargs):
    kwargs['flush'] = True
    print(*args, **kwargs)


for line in iter(sys.stdin.readline, ''):
    line = line.rstrip('\n')
    if not line:
        continue
    try:
        ev = json.loads(line)
    except json.JSONDecodeError:
        print_flushed(line)
        continue

    t = ev.get('type')
    if t == 'system' and ev.get('subtype') == 'init':
        print_flushed(
            f"[session] started "
            f"(id: {ev.get('session_id', '?')}, "
            f"model: {ev.get('model', '?')}, "
            f"cwd: {ev.get('cwd', '?')})"
        )
    elif t == 'assistant':
        msg = ev.get('message', {})
        content = msg.get('content') or []
        if isinstance(content, str):
            if content.strip():
                print_flushed(content)
        else:
            for item in content:
                it = item.get('type')
                if it == 'text':
                    txt = item.get('text', '')
                    if txt.strip():
                        print_flushed(txt)
                elif it == 'tool_use':
                    name = item.get('name', '?')
                    print_flushed(f"[tool] {name}({brief(item.get('input', {}), 400)})")
    elif t == 'user':
        msg = ev.get('message', {})
        content = msg.get('content') or []
        if isinstance(content, str):
            # Plain prompt (from the session transcript, not stream-json).
            if content.strip():
                print_flushed(f"[user] {brief(content, 600)}")
        else:
            for item in content:
                if item.get('type') == 'tool_result':
                    c = item.get('content', '')
                    if isinstance(c, list):
                        c = ' '.join(x.get('text', '') for x in c if isinstance(x, dict))
                    is_err = item.get('is_error')
                    tag = 'tool-err' if is_err else 'tool-ok'
                    print_flushed(f"[{tag}] {brief(c, 600)}")
    elif t in ('queue-operation', 'last-prompt'):
        # Internal transcript metadata — skip.
        continue
    elif t == 'result':
        usage = ev.get('usage', {})
        duration_ms = ev.get('duration_ms')
        header = '\n--- FINAL ---'
        if duration_ms is not None:
            header += f" ({duration_ms // 1000}s"
            if usage:
                header += f", in={usage.get('input_tokens', 0)} out={usage.get('output_tokens', 0)}"
            header += ')'
        print_flushed(header)
        print_flushed(ev.get('result', '<no result>'))
