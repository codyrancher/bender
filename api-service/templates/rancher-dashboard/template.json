{
  "name": "Rancher Dashboard",
  "description": "Rancher dev environment",
  "keys": [
    { "id": "figmaApiKey", "label": "Figma API Key", "description": "Personal access token for Figma MCP server" },
    { "id": "appcoEmail", "label": "AppCo Email", "description": "Email address for AppCo OCI registry authentication", "isText": true, "placeholder": "user@example.com" },
    { "id": "appcoToken", "label": "AppCo Access Token", "description": "Access token for AppCo OCI registry authentication" },
    { "id": "rancherTag", "label": "Rancher Tag", "description": "Default Rancher image tag (e.g. head, v2.10-head)", "isText": true, "placeholder": "head" }
  ],
  "sidecars": [
    {
      "suffix": "rancher",
      "image": "rancher/rancher:{{settings.rancherTag}}",
      "env": {
        "CATTLE_BOOTSTRAP_PASSWORD": "{{harness.adminPassword}}"
      },
      "privileged": true,
      "volumes": [
        "/data/rancher-data/{{projectName}}:/var/lib/rancher"
      ]
    },
    {
      "suffix": "browser",
      "image": "lscr.io/linuxserver/chromium:latest",
      "shm_size": "1gb",
      "network_container": true,
      "entrypoint": "bash",
      "volumes": [
        "/data/projects/{{projectName}}/browser-ext:/opt/autofill-ext:ro"
      ],
      "env": {
        "PUID": "1000",
        "PGID": "1000",
        "CUSTOM_PORT": "3000",
        "SELKIES_JPEG_QUALITY": "100",
        "SELKIES_H264_FULLCOLOR": "true",
        "CHROME_CLI": "https://{{projectName}}-rancher https://localhost:8005 --no-first-run --start-maximized --disable-infobars --allow-insecure-localhost --ignore-certificate-errors --force-dark-mode --remote-debugging-port=9222 --remote-debugging-address=0.0.0.0 --load-extension=/opt/autofill-ext"
      },
      "command": ["-c", "mkdir -p /etc/chromium/policies/managed && echo '{\"ExtensionInstallForcelist\":[\"nhdogjmejiglipccpnnnanhbledajbpd;https://clients2.google.com/service/update2/crx\"]}' > /etc/chromium/policies/managed/extensions.json && exec /init"]
    },
    {
      "suffix": "figma",
      "image": "acuvity/mcp-server-figma:latest",
      "env": {
        "FIGMA_API_KEY": "{{settings.figmaApiKey}}"
      }
    }
  ]
}
