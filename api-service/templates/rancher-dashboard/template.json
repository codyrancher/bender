{
  "name": "Rancher Dashboard",
  "description": "Rancher dev environment",
  "sidecars": [
    {
      "suffix": "rancher",
      "image": "rancher/rancher:{{args.RANCHER_TAG}}",
      "env": {
        "CATTLE_BOOTSTRAP_PASSWORD": "{{harness.adminPassword}}"
      },
      "privileged": true,
      "entrypoint": "bash",
      "command": ["-c", "mkdir -p /etc/rancher/k3s && printf 'snapshotter: native\n' > /etc/rancher/k3s/config.yaml && exec /usr/bin/entrypoint.sh"],
      "volumes": [
        "/data/rancher-data/{{projectName}}:/var/lib/rancher"
      ]
    },
    {
      "suffix": "browser",
      "image": "lscr.io/linuxserver/chromium:latest",
      "shm_size": "1gb",
      "network_container": true,
      "entrypoint": "bash",
      "volumes": [
        "/data/pipelines/{{projectName}}/browser-ext:/opt/autofill-ext:ro"
      ],
      "env": {
        "PUID": "1000",
        "PGID": "1000",
        "CUSTOM_PORT": "3000",
        "SELKIES_JPEG_QUALITY": "100",
        "SELKIES_H264_FULLCOLOR": "true",
        "CHROME_CLI": "https://{{projectName}}-rancher https://localhost:8005 --no-first-run --start-maximized --disable-infobars --allow-insecure-localhost --ignore-certificate-errors --force-dark-mode --remote-debugging-port=9222 --remote-debugging-address=0.0.0.0 --load-extension=/opt/autofill-ext"
      },
      "command": ["-c", "mkdir -p /etc/chromium/policies/managed && echo '{\"ExtensionInstallForcelist\":[\"nhdogjmejiglipccpnnnanhbledajbpd;https://clients2.google.com/service/update2/crx\"]}' > /etc/chromium/policies/managed/extensions.json && exec /init"]
    }
  ]
}
