# Bender environment configuration
#
# Copy this file to `.env` and fill in values. All configurable keys are now
# set here (the in-app template-keys UI has been removed). `.env` is injected
# into the container via docker-compose and forwarded to the API service.

# --- Host user (run: id -u && id -g) ---
PUID=1000
PGID=1000

# --- Claude CLI ---
# The Claude CLI that executes pipeline stages authenticates via interactive
# login (per pipeline, from the portal); credentials persist in /data/credentials.
# No API key is configured here.

# --- GitHub OAuth (portal login) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Rancher dev environment ---
# Default Rancher image tag used by the rancher sidecar (e.g. head, v2.13-head).
RANCHER_TAG=head




# --- Cloud credentials ---
### THESE WILL NOT BE USEFUL UNTIL WE SETUP TUNNELING OR ACCESS TO THE RANCHER SERVER, I DID THIS PREVIOUSLY WITH PORT FORWARDING
## AWS (e.g. for EC2 provisioning / S3). Region defaults to us-west-2.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2

## DigitalOcean personal access token (doctl / API).
# DIGITALOCEAN_ACCESS_TOKEN=
