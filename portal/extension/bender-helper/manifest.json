{
  "manifest_version": 3,
  "name": "Bender Helper",
  "version": "1.9",
  "description": "Isolates VS Code storage per project and reports the installed extension version to the harness.",
  "permissions": [],
  "host_permissions": [
    "https://code.ourhome.dev/*",
    "http://localhost:8008/*",
    "https://localhost:4443/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://code.ourhome.dev/*",
        "http://localhost:8008/*",
        "https://localhost:4443/*"
      ],
      "js": ["isolate.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "https://code.ourhome.dev/*",
        "http://localhost:8008/*",
        "https://localhost:4443/*"
      ],
      "js": ["extension-info.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
